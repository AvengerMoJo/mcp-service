# MCP server
MCP_PORT=8000
MCP_REQUIRE_AUTH=false
MCP_API_KEY=change-me

# OAuth 2.1 Authorization Server
OAUTH_ENABLED=true
OAUTH_AUTO_APPROVE=true           # skip consent page (personal assistant)
OAUTH_STORAGE_DIR=~/.mcp_service/oauth

# Token lifetimes (seconds)
OAUTH_ACCESS_TOKEN_TTL=3600       # 1 hour
OAUTH_REFRESH_TOKEN_TTL=2592000   # 30 days
OAUTH_AUTH_CODE_TTL=600           # 10 minutes

# JWT validation (for external tokens — leave blank when using built-in AS)
# OAUTH_ISSUER=https://accounts.google.com
# OAUTH_AUDIENCE=your-audience
# OAUTH_JWKS_URI=https://accounts.google.com/.well-known/jwks.json
# JWT_SECRET=your-secret
